{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LUMA",
  "version": "0.1.0",
  "identifier": "com.santiagorada.luma",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LUMA",
        "url": "index.html",
        "width": 560,
        "height": 460,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "copy-color-overlay",
        "title": "Copiar color",
        "url": "copy-color-overlay.html",
        "width": 326,
        "height": 110,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "luma-translate-this",
        "title": "Translate This",
        "url": "translate-this.html",
        "width": 520,
        "height": 420,
        "visible": false,
        "decorations": true,
        "resizable": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "luma-contar-caracteres",
        "title": "ContarCaracteres",
        "url": "contar-caracteres.html",
        "width": 520,
        "height": 430,
        "visible": false,
        "decorations": true,
        "resizable": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "luma-merge-pdf",
        "title": "Merge PDF",
        "url": "merge-pdf.html",
        "width": 540,
        "height": 460,
        "visible": false,
        "decorations": true,
        "resizable": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "luma-image-convert",
        "title": "Image Convert",
        "url": "image-convert.html",
        "width": 560,
        "height": 520,
        "visible": false,
        "decorations": true,
        "resizable": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "luma-video-downloader",
        "title": "Video Downloader",
        "url": "video-downloader.html",
        "width": 560,
        "height": 500,
        "visible": false,
        "decorations": true,
        "resizable": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["../components"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "allowDowngrades": false,
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsh",
        "languages": ["Spanish", "English"]
      }
    }
  }
}
